#!/usr/bin/env bash
set -euo pipefail

formula_path=""
tap_dir=""
version=""
branch=""

while (($#)); do
  case "$1" in
    --formula)
      formula_path="$2"
      shift 2
      ;;
    --tap-dir)
      tap_dir="$2"
      shift 2
      ;;
    --version)
      version="$2"
      shift 2
      ;;
    --branch)
      branch="$2"
      shift 2
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

if [[ -z "${formula_path}" || -z "${tap_dir}" || -z "${version}" || -z "${branch}" ]]; then
  echo "formula, tap-dir, version, and branch are required" >&2
  exit 1
fi

if [[ -z "${EASYHARNESS_HOMEBREW_TAP_TOKEN:-}" ]]; then
  echo "::warning title=Homebrew tap update skipped::EASYHARNESS_HOMEBREW_TAP_TOKEN is not set; skipping Homebrew tap update."
  exit 0
fi

if [[ ! -f "${formula_path}" ]]; then
  echo "formula file not found: ${formula_path}" >&2
  exit 1
fi

if ! git -C "${tap_dir}" rev-parse --git-dir >/dev/null 2>&1; then
  echo "tap dir is not a git checkout: ${tap_dir}" >&2
  exit 1
fi

mkdir -p "${tap_dir}/Formula"
cp "${formula_path}" "${tap_dir}/Formula/easyharness.rb"

if [[ -z "$(git -C "${tap_dir}" status --short -- Formula/easyharness.rb)" ]]; then
  echo "Homebrew formula already up to date."
  exit 0
fi

git -C "${tap_dir}" config user.name "github-actions[bot]"
git -C "${tap_dir}" config user.email "41898282+github-actions[bot]@users.noreply.github.com"
git -C "${tap_dir}" add Formula/easyharness.rb
git -C "${tap_dir}" commit -m "Update easyharness formula for ${version}"
git -C "${tap_dir}" push origin "HEAD:refs/heads/${branch}"
